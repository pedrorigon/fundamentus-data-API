FUNDAMENTUS_API_BIND_HOST=127.0.0.1
FUNDAMENTUS_API_BIND_PORT=8000
FUNDAMENTUS_API_ENVIRONMENT=local
FUNDAMENTUS_API_TIMEZONE=America/Sao_Paulo

FUNDAMENTUS_API_FUNDAMENTUS_BASE_URL=https://www.fundamentus.com.br
FUNDAMENTUS_API_USER_AGENT=fundamentus-data-api/0.1 local scraper (contact: local-development; purpose: personal local API)
FUNDAMENTUS_API_REQUEST_TIMEOUT_SECONDS=10
FUNDAMENTUS_API_MAX_CONNECTIONS=8
FUNDAMENTUS_API_MAX_KEEPALIVE_CONNECTIONS=4
FUNDAMENTUS_API_UPSTREAM_CONCURRENCY=4
FUNDAMENTUS_API_UPSTREAM_MIN_INTERVAL_SECONDS=0.15

FUNDAMENTUS_API_RETRY_ATTEMPTS=3
FUNDAMENTUS_API_RETRY_BACKOFF_SECONDS=0.25
FUNDAMENTUS_API_CIRCUIT_BREAKER_FAILURES=5
FUNDAMENTUS_API_CIRCUIT_BREAKER_RECOVERY_SECONDS=60

FUNDAMENTUS_API_MARKET_DATA_TTL_SECONDS=300
FUNDAMENTUS_API_FUNDAMENTALS_TTL_SECONDS=3600
FUNDAMENTUS_API_DIVIDENDS_TTL_SECONDS=21600
FUNDAMENTUS_API_CACHE_HEADERS_MAX_AGE_SECONDS=60

FUNDAMENTUS_API_SQLITE_CACHE_ENABLED=true
FUNDAMENTUS_API_SQLITE_CACHE_PATH=.cache/fundamentus_cache.sqlite3
FUNDAMENTUS_API_BATCH_LIMIT=20
FUNDAMENTUS_API_CACHE_INVALIDATE_TOKEN=
